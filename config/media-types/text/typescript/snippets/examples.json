{
  "Import": {
    "prefix": "imp",
    "body": ["import { ${1:name} } from \"${2:module}\";$0"],
    "description": "Named import"
  },
  "Import default": {
    "prefix": "impd",
    "body": ["import ${1:name} from \"${2:module}\";$0"],
    "description": "Default import"
  },
  "Export": {
    "prefix": "exp",
    "body": ["export ${0}"],
    "description": "export"
  },
  "Interface": {
    "prefix": "interface",
    "body": ["interface ${1:Name} {", "\t${2:field}: ${3:string};", "}$0"],
    "description": "Interface declaration"
  },
  "Type alias": {
    "prefix": "type",
    "body": ["type ${1:Name} = ${0:type};"],
    "description": "Type alias"
  },
  "Enum": {
    "prefix": "enum",
    "body": ["enum ${1:Name} {", "\t${2:A},", "\t${3:B},", "}$0"],
    "description": "Enum declaration"
  },
  "Function": {
    "prefix": "fn",
    "body": ["function ${1:name}(${2:args}): ${3:void} {", "\t$0", "}"],
    "description": "Function declaration"
  },
  "Arrow function": {
    "prefix": "afn",
    "body": ["const ${1:name} = (${2:args}): ${3:void} => {", "\t$0", "};"],
    "description": "Arrow function"
  },
  "Async function": {
    "prefix": "afne",
    "body": ["async function ${1:name}(${2:args}): Promise<${3:void}> {", "\t$0", "}"],
    "description": "Async function"
  },
  "Class": {
    "prefix": "class",
    "body": [
      "class ${1:Name} {",
      "\tconstructor(${2:args}) {",
      "\t\t$0",
      "\t}",
      "}"
    ],
    "description": "Class with constructor"
  },
  "Console log": {
    "prefix": "clg",
    "body": ["console.log(${0});"],
    "description": "console.log"
  },
  "For of": {
    "prefix": "forof",
    "body": ["for (const ${1:item} of ${2:iterable}) {", "\t$0", "}"],
    "description": "for...of loop"
  },
  "If": {
    "prefix": "if",
    "body": ["if (${1:condition}) {", "\t$0", "}"],
    "description": "if statement"
  },
  "Try/catch": {
    "prefix": "try",
    "body": ["try {", "\t${1}", "} catch (${2:err}) {", "\t$0", "}"],
    "description": "try/catch block"
  },
  "Switch": {
    "prefix": "switch",
    "body": [
      "switch (${1:value}) {",
      "\tcase ${2:a}:",
      "\t\t$0",
      "\t\tbreak;",
      "\tdefault:",
      "\t\tbreak;",
      "}"
    ],
    "description": "switch statement"
  },
  "Promise": {
    "prefix": "promise",
    "body": ["new Promise<${1:void}>((resolve, reject) => {", "\t$0", "});"],
    "description": "new Promise"
  }
}
