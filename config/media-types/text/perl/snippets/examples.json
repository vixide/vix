{
  "Shebang": { "prefix": "shebang", "body": ["#!/usr/bin/env perl", "use strict;", "use warnings;", "", "$0"], "description": "Perl shebang with strict/warnings" },
  "Subroutine": { "prefix": "sub", "body": ["sub ${1:name} {", "\tmy (${2:\\$args}) = @_;", "\t$0", "}"], "description": "Subroutine" },
  "If": { "prefix": "if", "body": ["if (${1:condition}) {", "\t$0", "}"], "description": "if statement" },
  "Foreach": { "prefix": "foreach", "body": ["foreach my \\$${1:item} (${2:@list}) {", "\t$0", "}"], "description": "foreach loop" },
  "While": { "prefix": "while", "body": ["while (${1:condition}) {", "\t$0", "}"], "description": "while loop" },
  "Open file": { "prefix": "open", "body": ["open(my \\$${1:fh}, '<', ${2:\\$path}) or die \"\\$!\";", "$0", "close(\\$${1:fh});"], "description": "Open and close a file" },
  "Print": { "prefix": "print", "body": ["print ${0};"], "description": "print" },
  "Hash": { "prefix": "hash", "body": ["my %${1:hash} = (", "\t${2:key} => ${0:value},", ");"], "description": "Hash literal" },
  "Array": { "prefix": "array", "body": ["my @${1:array} = (${0});"], "description": "Array literal" },
  "Use module": { "prefix": "use", "body": ["use ${0:Module};"], "description": "use module" }
}
