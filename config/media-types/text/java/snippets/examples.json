{
  "Class": {
    "prefix": "class",
    "body": ["public class ${1:Name} {", "\t$0", "}"],
    "description": "Public class"
  },
  "Main method": {
    "prefix": "main",
    "body": ["public static void main(String[] args) {", "\t$0", "}"],
    "description": "main method"
  },
  "Method": {
    "prefix": "method",
    "body": ["public ${1:void} ${2:name}(${3:args}) {", "\t$0", "}"],
    "description": "Method"
  },
  "System out": {
    "prefix": "sout",
    "body": ["System.out.println(${0});"],
    "description": "System.out.println"
  },
  "For loop": {
    "prefix": "for",
    "body": ["for (int ${1:i} = 0; ${1:i} < ${2:n}; ${1:i}++) {", "\t$0", "}"],
    "description": "for loop"
  },
  "For each": {
    "prefix": "foreach",
    "body": ["for (${1:Type} ${2:item} : ${3:collection}) {", "\t$0", "}"],
    "description": "Enhanced for loop"
  },
  "If": {
    "prefix": "if",
    "body": ["if (${1:condition}) {", "\t$0", "}"],
    "description": "if statement"
  },
  "Try/catch": {
    "prefix": "try",
    "body": ["try {", "\t${1}", "} catch (${2:Exception} ${3:e}) {", "\t$0", "}"],
    "description": "try/catch block"
  },
  "Interface": {
    "prefix": "interface",
    "body": ["public interface ${1:Name} {", "\t$0", "}"],
    "description": "Interface"
  },
  "Constructor": {
    "prefix": "ctor",
    "body": ["public ${1:Name}(${2:args}) {", "\t$0", "}"],
    "description": "Constructor"
  },
  "Getter": {
    "prefix": "get",
    "body": ["public ${1:Type} get${2:Name}() {", "\treturn ${3:field};", "}$0"],
    "description": "Getter method"
  },
  "Setter": {
    "prefix": "set",
    "body": ["public void set${1:Name}(${2:Type} ${3:value}) {", "\tthis.${4:field} = ${3:value};", "}$0"],
    "description": "Setter method"
  },
  "Switch": {
    "prefix": "switch",
    "body": [
      "switch (${1:value}) {",
      "\tcase ${2:a}:",
      "\t\t$0",
      "\t\tbreak;",
      "\tdefault:",
      "\t\tbreak;",
      "}"
    ],
    "description": "switch statement"
  },
  "While": {
    "prefix": "while",
    "body": ["while (${1:condition}) {", "\t$0", "}"],
    "description": "while loop"
  }
}
