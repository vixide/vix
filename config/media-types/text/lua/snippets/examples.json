{
  "Function": {
    "prefix": "fn",
    "body": ["function ${1:name}(${2:args})", "\t$0", "end"],
    "description": "Function"
  },
  "Local function": {
    "prefix": "lfn",
    "body": ["local function ${1:name}(${2:args})", "\t$0", "end"],
    "description": "Local function"
  },
  "If": {
    "prefix": "if",
    "body": ["if ${1:condition} then", "\t$0", "end"],
    "description": "if statement"
  },
  "If/else": {
    "prefix": "ife",
    "body": ["if ${1:condition} then", "\t${2}", "else", "\t$0", "end"],
    "description": "if/else statement"
  },
  "For numeric": {
    "prefix": "for",
    "body": ["for ${1:i} = ${2:1}, ${3:n} do", "\t$0", "end"],
    "description": "Numeric for loop"
  },
  "For pairs": {
    "prefix": "forp",
    "body": ["for ${1:k}, ${2:v} in pairs(${3:t}) do", "\t$0", "end"],
    "description": "Generic for over pairs"
  },
  "For ipairs": {
    "prefix": "fori",
    "body": ["for ${1:i}, ${2:v} in ipairs(${3:t}) do", "\t$0", "end"],
    "description": "Generic for over ipairs"
  },
  "While": {
    "prefix": "while",
    "body": ["while ${1:condition} do", "\t$0", "end"],
    "description": "while loop"
  },
  "Repeat": {
    "prefix": "repeat",
    "body": ["repeat", "\t$0", "until ${1:condition}"],
    "description": "repeat/until loop"
  },
  "Table": {
    "prefix": "table",
    "body": ["local ${1:t} = {", "\t${0}", "}"],
    "description": "Table literal"
  },
  "Require": {
    "prefix": "require",
    "body": ["local ${1:mod} = require(\"${2:module}\")$0"],
    "description": "require module"
  },
  "Print": { "prefix": "print", "body": ["print(${0})"], "description": "print" }
}
