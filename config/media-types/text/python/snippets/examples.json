{
  "Main guard": {
    "prefix": "main",
    "body": ["if __name__ == \"__main__\":", "\t${1:main()}"],
    "description": "if __name__ == \"__main__\" guard"
  },
  "Function": {
    "prefix": "def",
    "body": ["def ${1:name}(${2:args}):", "\t\"\"\"${3:docstring}\"\"\"", "\t${0:pass}"],
    "description": "Function definition with docstring"
  },
  "Async function": {
    "prefix": "adef",
    "body": ["async def ${1:name}(${2:args}):", "\t${0:pass}"],
    "description": "Async function definition"
  },
  "Class": {
    "prefix": "class",
    "body": [
      "class ${1:Name}:",
      "\tdef __init__(self, ${2:args}):",
      "\t\t${0:pass}"
    ],
    "description": "Class with constructor"
  },
  "Dataclass": {
    "prefix": "dataclass",
    "body": [
      "from dataclasses import dataclass",
      "",
      "@dataclass",
      "class ${1:Name}:",
      "\t${2:field}: ${3:int}",
      "$0"
    ],
    "description": "Dataclass"
  },
  "If": {
    "prefix": "if",
    "body": ["if ${1:condition}:", "\t${0:pass}"],
    "description": "if statement"
  },
  "If/else": {
    "prefix": "ife",
    "body": ["if ${1:condition}:", "\t${2:pass}", "else:", "\t${0:pass}"],
    "description": "if/else statement"
  },
  "For loop": {
    "prefix": "for",
    "body": ["for ${1:item} in ${2:iterable}:", "\t${0:pass}"],
    "description": "for loop"
  },
  "For enumerate": {
    "prefix": "fore",
    "body": ["for ${1:i}, ${2:item} in enumerate(${3:iterable}):", "\t${0:pass}"],
    "description": "for loop with enumerate"
  },
  "While loop": {
    "prefix": "while",
    "body": ["while ${1:condition}:", "\t${0:pass}"],
    "description": "while loop"
  },
  "Try/except": {
    "prefix": "try",
    "body": ["try:", "\t${1:pass}", "except ${2:Exception} as ${3:e}:", "\t${0:pass}"],
    "description": "try/except block"
  },
  "With open": {
    "prefix": "with",
    "body": ["with open(${1:path}, \"${2:r}\") as ${3:f}:", "\t${0:pass}"],
    "description": "with open(...) as f"
  },
  "List comprehension": {
    "prefix": "lc",
    "body": ["[${1:expr} for ${2:item} in ${3:iterable}]$0"],
    "description": "List comprehension"
  },
  "Dict comprehension": {
    "prefix": "dc",
    "body": ["{${1:key}: ${2:value} for ${3:item} in ${4:iterable}}$0"],
    "description": "Dict comprehension"
  },
  "Lambda": {
    "prefix": "lambda",
    "body": ["lambda ${1:x}: ${0:x}"],
    "description": "Lambda expression"
  },
  "Print": {
    "prefix": "pr",
    "body": ["print(${0})"],
    "description": "print(...)"
  },
  "F-string print": {
    "prefix": "prf",
    "body": ["print(f\"${1:text} {${2:value}}\")$0"],
    "description": "print with f-string"
  },
  "Import": {
    "prefix": "imp",
    "body": ["import ${0:module}"],
    "description": "import module"
  },
  "From import": {
    "prefix": "from",
    "body": ["from ${1:module} import ${0:name}"],
    "description": "from module import name"
  },
  "Property": {
    "prefix": "prop",
    "body": ["@property", "def ${1:name}(self):", "\treturn self._${1:name}$0"],
    "description": "Property getter"
  }
}
