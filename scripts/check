#!/bin/sh
# Local CI-parity gate for Vix. Run before pushing or opening a PR.
#
# Mirrors the bar every change must clear: it checks formatting with rustfmt,
# builds, runs Clippy at the pedantic level with warnings denied (the project's
# hard rule), and runs the full test suite (unit + integration + doctests).
# Stops at the first failure. See spec/rust-cargo-fmt.
set -e

echo "==> cargo fmt --check"
cargo fmt --check

echo "==> cargo build"
cargo build --all-targets

echo "==> cargo clippy (pedantic, -D warnings)"
cargo clippy --all-targets -- -D warnings

echo "==> cargo test"
cargo test

echo "OK: build + clippy + tests all passed"
