#!/bin/sh
# Local CI-parity gate for Vix. Run before pushing or opening a PR.
#
# Mirrors the bar every change must clear: it builds, runs Clippy at the
# pedantic level with warnings denied (the project's hard rule), and runs the
# full test suite (unit + integration + doctests). Stops at the first failure.
#
# Note: `cargo fmt` is intentionally NOT run — Vix uses hand-tuned formatting
# (no rustfmt.toml) and is not rustfmt-clean by design.
set -e

echo "==> cargo build"
cargo build --all-targets

echo "==> cargo clippy (pedantic, -D warnings)"
cargo clippy --all-targets -- -D warnings

echo "==> cargo test"
cargo test

echo "OK: build + clippy + tests all passed"
